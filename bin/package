#!/usr/bin/env bash

set -euxo pipefail

VERSION=${REF#"refs/tags/"}
DIST=`pwd`/dist

echo "Packaging btcc20-inscriber $VERSION for $TARGET..."

test -f Cargo.lock || cargo generate-lockfile

echo "Building ord..."
RUSTFLAGS="--deny warnings $TARGET_RUSTFLAGS" \
  cargo build --bin ord --target $TARGET --release
EXECUTABLE=target/$TARGET/release/ord

if [[ $OS == windows-latest ]]; then
  EXECUTABLE=$EXECUTABLE.exe
fi

echo "Copying release files..."
PACKAGE=btcc20-inscriber-$VERSION
mkdir -p dist/$PACKAGE
cp \
  Cargo.lock \
  Cargo.toml \
  LICENSE \
  README.md \
  btcc20-profiles.conf \
  $DIST/$PACKAGE

if [[ $OS == windows-latest ]]; then
  cp "$EXECUTABLE" "$DIST/$PACKAGE/ord.exe"
  cp windows/BTCC20-Inscriber.bat "$DIST/$PACKAGE"
  cp windows/README.md "$DIST/$PACKAGE/WINDOWS.md"
else
  cp "$EXECUTABLE" "$DIST/$PACKAGE/ord"
  cp btcc20-inscriber "$DIST/$PACKAGE"
  cp btcc20-mint-many "$DIST/$PACKAGE"
fi

cd $DIST
echo "Creating release archive..."
case $OS in
  ubuntu-latest | macos-latest)
    ARCHIVE=$DIST/btcc20-inscriber-$VERSION-$TARGET.tar.gz
    tar czf $ARCHIVE *
    if [[ -n "${GITHUB_OUTPUT+x}" ]]; then
      echo archive=$ARCHIVE >> $GITHUB_OUTPUT
    fi
    ;;
  windows-latest)
    ARCHIVE=$DIST/btcc20-inscriber-$VERSION-$TARGET.zip
    7z a $ARCHIVE *
    if [[ -n "${GITHUB_OUTPUT+x}" ]]; then
      echo archive=`pwd -W`/btcc20-inscriber-$VERSION-$TARGET.zip >> $GITHUB_OUTPUT
    fi
    ;;
esac
